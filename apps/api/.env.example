# ---- Runtime ----
NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql://teamflow:teamflow@localhost:5433/teamflow?schema=public

# ---- JWT ----
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# ---- AWS (S3) ----
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=teamflow-uploads
AWS_S3_PUBLIC_URL=

# ---- Logging ----
LOG_LEVEL=debug
